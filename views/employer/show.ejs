<% layout('layouts/boilerplate') %> 
    <div class="row">
        <div class="col-6">
            <div class="card">
                <div class="card-body">
                    <% for (img of employer.image) {%>
                        <img src="<%= img.url %>" alt="company-logo" class="rounded" width="100px">
                        <% } %>  
                  <h5 class="card-title"><%= employer.name %></h5>
                  <p class="card-text"><%= employer.address %></p>
                </div>
                <ul class="list-group list-group-flush">
                  <li class="list-group-item"><%= employer.industry %></li>
                  <% for (let lowongan of employer.lowongan) { %> 
                  <li class="list-group-item"><a href="/lowongan/<%= lowongan._id %>"><%= lowongan.title %></li></a>
                  <% } %> 
                </ul>
                <!-- <div class="card-body">
                    <form action="/employer/<%= employer._id %>?_method=DELETE" method="post">
                        <button class="btn btn-danger">Delete</button>
                    </form>
                </div> -->
                <div class="card-footer">
                    <small class="text-muted">Posted 3 days ago</small>
                </div>
              </div>
        </div>
    </div>