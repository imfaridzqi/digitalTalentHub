<% layout('layouts/boilerplate') %> 
<div class="row">
    <div class="col-4">
        <div class="card">
            <div class="card-header">Profile</div>
            <% for (let img of alumni.image) {%> 
            <img src="<%= img.url %>" class="rounded ml-3 d-block mt-2" width="100px" alt="profile-img">
            <% } %> 
            <div class="card-body">
              <h5 class="card-title"><%= alumni.name %> <%= alumni.lastName %> </h5>
              <p class="card-text"><%= alumni.email %></p>
              <p class="card-text"><%= alumni.phone %></p>
              <p class="card-text"><%= alumni.description %></p>
              <p class="card-text"><%= alumni.tglRegistrasi %></p>
              <a href="/alumni/<%= alumni._id %>/edit-profile" class="btn btn-primary">Edit Profile</a>
            </div>
          </div>
    </div>
</div>
