<% layout('layouts/boilerplate') %> 
    <div class="row">
        <div class="col-6">
            <div class="card">
                <div class="card-body">
                  <% for (let img of alumni.image) {%> 
                  <img src="<%= img.url %>" class="rounded" width="100px">
                  <% } %> 
                  <h5 class="card-title"><%= alumni.name %> <%= alumni.lastName %></h5>
                  <p class="card-text"><%= alumni.email %></p>
                  <p class="card-text"><%= alumni.phone %></p>
                  <p class="card-text"><%= alumni.description %></p>
                </div>
                <ul class="list-group list-group-flush">
                  <li class="list-group-item"></li>
                  
                  <li class="list-group-item"><a href="""></li></a>

                </ul>
                <div class="card-footer">
                    <small class="text-muted">Posted 3 days ago</small>
                </div>
              </div>
        </div>
    </div>