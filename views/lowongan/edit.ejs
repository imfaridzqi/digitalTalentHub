<% layout('layouts/boilerplate') %>
<div class="row">
    <div class="col-6 offset-3">
        <h1>Edit Lowongan</h1>
        <form action="/lowongan/<%= lowongan._id %>?_method=PUT" method="post" class="needs-validation" novalidate>
        <div class="form-outline mb-4">
            <input type="text" name="lowongan[title]" class="form-control" id="title" value="<%= lowongan.title %>" required>
            <label for="title" class="form-label">Title</label>
            <div class="invalid-feedback">Kolom ini harus diisi</div>
        </div>
        <div class="form-outline mb-4">
            <input type="text" name="lowongan[location]" class="form-control" id="location" value="<%= lowongan.location %>" required>
            <label for="location" class="form-label">Location</label>
            <div class="invalid-feedback">Kolom ini harus diisi</div>
        </div>
        <div class="form-outline mb-4">
            <input type="text" name="lowongan[salary]" class="form-control" id="salary" value="<%= lowongan.salary %>" required>
            <label for="salary" class="form-label">Salary</label>
            <div class="invalid-feedback">Kolom ini harus diisi</div>
        </div>
        <div class="form-outline mb-4">
            <input type="text" name="lowongan[description]" class="form-control" id="description" value="<%= lowongan.description %>" required>
            <label for="description" class="form-label">Description</label>
            <div class="invalid-feedback">Kolom ini harus diisi</div>
        </div>
        <button type="submit" class="btn btn-primary block">Edit Lowongan</button>
    </form>
    <a href="/lowongan/<%= lowongan._id %>">Batal dan Kembali</a>

    </div>
</div>
    